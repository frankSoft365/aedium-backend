<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.microsoft.aediumbackend.mapper.UserMapper">
    <select id="getUsersBriefByIds" resultType="com.microsoft.aediumbackend.model.dto.user.response.UserBriefDTO">
        select
            id,
            username,
            image
        from user
        where
            is_delete=0
        and id in
        <foreach collection="userIds" item="userId" open="(" separator="," close=")">
            #{userId}
        </foreach>
    </select>

</mapper>
